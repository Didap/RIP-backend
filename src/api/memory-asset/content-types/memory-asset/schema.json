{
  "kind": "collectionType",
  "collectionName": "memory_assets",
  "info": {
    "singularName": "memory-asset",
    "pluralName": "memory-assets",
    "displayName": "Memory Asset",
    "description": "Il Diamante - Ricordi multimediali"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "file": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "videos",
        "files",
        "audios"
      ]
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "event_date": {
      "type": "date"
    },
    "memorial": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::memorial.memorial",
      "inversedBy": "memory_assets"
    }
  }
}
