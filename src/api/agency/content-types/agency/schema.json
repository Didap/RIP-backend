{
  "kind": "collectionType",
  "collectionName": "agencies",
  "info": {
    "singularName": "agency",
    "pluralName": "agencies",
    "displayName": "Agency",
    "description": "Imprese funebri partner"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "vat_number": {
      "type": "string",
      "unique": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "address": {
      "type": "json"
    },
    "coordinates": {
      "type": "json"
    },
    "website": {
      "type": "string"
    },
    "owner": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "staff": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "agencies"
    },
    "tombstones": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tombstone.tombstone",
      "mappedBy": "agency"
    }
  }
}
