    "access_code": {
      "type": "string",
      "unique": true,
      "required": true
    },
    "description": {
      "type": "text"
    },
    "members": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::family-member.family-member",
      "mappedBy": "family"
    }
  }
}
