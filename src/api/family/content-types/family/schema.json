{
  "kind": "collectionType",
  "collectionName": "families",
  "info": {
    "singularName": "family",
    "pluralName": "families",
    "displayName": "Family",
    "description": "Gestione delle famiglie degli utenti"
  },
  "options": {
    "draftAndPublish": false
  },
